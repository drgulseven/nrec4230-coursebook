        "#| label: futures-hedge-example\n",
        "#| echo: true\n",
        "\n",
        "Q = 200\n",
        "contract_size = 10\n",
        "\n",
        "S0 = 123\n",
        "F0 = 125\n",
        "ST = 105\n",
        "FT = 110\n",
        "\n",
        "contracts = Q / contract_size\n",
        "spot_revenue = Q * ST\n",
        "futures_gain = (F0 - FT) * Q\n",
        "hedged_revenue = spot_revenue + futures_gain\n",
        "\n",
        "basis_0 = S0 - F0\n",
        "basis_T = ST - FT\n",
        "effective_price = hedged_revenue / Q\n",
        "\n",
        "print(\"Contracts:\", contracts)\n",
        "print(\"Spot revenue:\", spot_revenue)\n",
        "print(\"Futures gain:\", futures_gain)\n",
        "print(\"Hedged revenue:\", hedged_revenue)\n",
        "print(\"Basis at time 0:\", basis_0)\n",
        "print(\"Basis at harvest:\", basis_T)\n",
        "print(\"Effective price:\", effective_price)"
