        "import pandas as pd\n",
        "\n",
        "initial_investment = 18000\n",
        "discount_rate = 0.08\n",
        "project_life = 5\n",
        "\n",
        "cash_flows = [4000, 4500, 5000, 5500, 6000]\n",
