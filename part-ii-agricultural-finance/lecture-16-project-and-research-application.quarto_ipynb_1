        "initial_investment = 8000\n",
        "annual_cash_flow = 2200\n",
        "salvage_value = 1000\n",
        "discount_rate = 0.08\n",
        "project_life = 5\n",
        "\n",
        "npv = -initial_investment\n",
        "for t in range(1, project_life + 1):\n",
        "    npv += annual_cash_flow / ((1 + discount_rate) ** t)\n",
        "npv += salvage_value / ((1 + discount_rate) ** project_life)\n",
        "\n",
        "round(npv, 2)"
      ],
