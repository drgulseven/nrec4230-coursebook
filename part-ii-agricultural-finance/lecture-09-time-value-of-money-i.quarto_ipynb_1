        "#| eval: false\n",
        "PV = 1000\n",
        "r = 0.08\n",
        "n = 2\n",
        "\n",
        "FVIF = (1 + r) ** n\n",
        "FV = PV * FVIF\n",
        "\n",
        "PVIF = 1 / ((1 + r) ** n)\n",
        "PV_again = FV * PVIF\n",
        "\n",
        "print(\"FVIF:\", round(FVIF, 4))\n",
        "print(\"Future Value:\", round(FV, 2))\n",
        "print(\"PVIF:\", round(PVIF, 4))\n",
        "print(\"Present Value:\", round(PV_again, 2))"
      ],
